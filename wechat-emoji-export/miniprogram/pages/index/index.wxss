.page {
  padding: 24rpx;
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
}

/* 使用说明 */
.tips-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.tips-line {
  font-size: 26rpx;
  color: #666;
  line-height: 1.8;
}

.tips-note {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #fa9d3b;
}

/* 操作按钮 */
.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-bottom: 24rpx;
}

/* 结果网格 */
.result-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.result-title {
  font-size: 30rpx;
  font-weight: 600;
}

.result-clear {
  font-size: 26rpx;
  color: #888;
}

.grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.grid-item {
  position: relative;
  width: 216rpx;
  height: 216rpx;
  border-radius: 8rpx;
  overflow: hidden;
  background: #f0f0f0;
}

.grid-img {
  width: 100%;
  height: 100%;
}

.grid-tag {
  position: absolute;
  right: 8rpx;
  bottom: 8rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #fff;
  font-size: 20rpx;
  padding: 2rpx 10rpx;
  border-radius: 6rpx;
}

.save-all {
  margin-top: 24rpx;
}

.pc-tip {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #888;
}

/* 空状态 */
.empty {
  text-align: center;
  color: #999;
  padding: 80rpx 0;
}

/* 隐藏画布：不能 display:none，否则无法取到节点，移出屏幕即可 */
.hidden-canvas {
  position: fixed;
  left: -9999px;
  top: -9999px;
  width: 100px;
  height: 100px;
}
